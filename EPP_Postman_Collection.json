{
  "info": {
    "name": "EPP — Encomendas por Pedido",
    "description": "Coleção completa das rotas EPP.\n\n⚠️ AUTENTICAÇÃO VIA COOKIE — faça login primeiro (pasta Auth). O Postman gerencia os cookies automaticamente.\n\nPara habilitar cookies no Postman: Settings → Cookies → Domains Allowlist → adicione 'vagas.gpprh.com.br'",
    "_postman_id": "epp-collection-2026",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://vagas.gpprh.com.br/api/v1/global",
      "type": "string",
      "description": "URL base da API"
    }
  ],
  "item": [

    {
      "name": "🔐 Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"seu.usuario\",\n  \"password\": \"sua.senha\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Autentica o usuário e grava os cookies accessToken, refreshToken e userRole.\n\nDepois do login o Postman passa os cookies automaticamente em todas as demais requisições."
          }
        },
        {
          "name": "Me (usuário logado)",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] },
            "description": "Retorna os dados do usuário autenticado via cookie."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] },
            "description": "Encerra a sessão e limpa os cookies."
          }
        }
      ]
    },

    {
      "name": "📦 Produtos",
      "item": [
        {
          "name": "Listar produtos ativos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/products",
              "host": ["{{base_url}}"],
              "path": ["epp", "products"]
            },
            "description": "Retorna lista reduzida de produtos ativos."
          }
        },
        {
          "name": "Listar TODOS os produtos",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/products?complete=1",
              "host": ["{{base_url}}"],
              "path": ["epp", "products"],
              "query": [{ "key": "complete", "value": "1" }]
            },
            "description": "Retorna todos os produtos (ativos e inativos), com mais detalhes."
          }
        },
        {
          "name": "Listar categorias",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/products?category=1",
              "host": ["{{base_url}}"],
              "path": ["epp", "products"],
              "query": [{ "key": "category", "value": "1" }]
            },
            "description": "Retorna apenas as categorias de produtos."
          }
        },
        {
          "name": "Buscar produto por filtro",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/products?id_category_fk=1&status_prod=1",
              "host": ["{{base_url}}"],
              "path": ["epp", "products"],
              "query": [
                { "key": "id_product",      "value": "",  "disabled": true,  "description": "ID exato do produto" },
                { "key": "id_category_fk",  "value": "1", "disabled": false, "description": "ID da categoria" },
                { "key": "status_prod",     "value": "1", "disabled": false, "description": "1=ativo, 0=inativo" }
              ]
            },
            "description": "Filtra produtos por id_product, id_category_fk e/ou status_prod."
          }
        },
        {
          "name": "Buscar produto por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/products/1",
              "host": ["{{base_url}}"],
              "path": ["epp", "products", "1"]
            },
            "description": "Retorna um produto específico pelo ID, incluindo nome da categoria."
          }
        },
        {
          "name": "Consultar produto no Consinco (Oracle)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/products/consinco?codigo_acesso=7891234567890&lojas=1",
              "host": ["{{base_url}}"],
              "path": ["epp", "products", "consinco"],
              "query": [
                { "key": "codigo_acesso", "value": "7891234567890", "description": "Código de barras (EAN) — OBRIGATÓRIO" },
                { "key": "lojas",         "value": "1",             "description": "Código(s) da loja separados por vírgula — OBRIGATÓRIO" },
                { "key": "full_store",    "value": "1",             "disabled": true, "description": "Se 1, consulta todas as lojas (1,2,3,7,8,9)" }
              ]
            },
            "description": "Consulta o produto no ERP Consinco via Oracle. Requer codigo_acesso (EAN) e lojas."
          }
        },
        {
          "name": "Criar produto",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/products", "host": ["{{base_url}}"], "path": ["epp", "products"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id_product\": 101,\n  \"description\": \"Bolo de Chocolate 1kg\",\n  \"price\": 45.90,\n  \"status_prod\": 1,\n  \"id_category_fk\": 2,\n  \"measure\": \"UN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Cria um novo produto.\n\nCampos obrigatórios: id_product, description, price, status_prod, id_category_fk, measure\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        },
        {
          "name": "Atualizar produto",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/products/1", "host": ["{{base_url}}"], "path": ["epp", "products", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Bolo de Chocolate 1,5kg\",\n  \"price\": 55.90,\n  \"status_prod\": 1,\n  \"id_category_fk\": 2,\n  \"measure\": \"UN\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Atualiza completamente um produto pelo ID.\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        },
        {
          "name": "Alterar status do produto",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/products/1/status", "host": ["{{base_url}}"], "path": ["epp", "products", "1", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status_prod\": 0\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Ativa (1) ou inativa (0) um produto sem alterar os outros campos.\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        },
        {
          "name": "Excluir produto",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/epp/products/1", "host": ["{{base_url}}"], "path": ["epp", "products", "1"] },
            "description": "Remove um produto. Bloqueado se houver pedidos vinculados.\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        }
      ]
    },

    {
      "name": "📋 Menus",
      "item": [
        {
          "name": "Listar menus ativos",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/epp/menus", "host": ["{{base_url}}"], "path": ["epp", "menus"] },
            "description": "Retorna menus ativos."
