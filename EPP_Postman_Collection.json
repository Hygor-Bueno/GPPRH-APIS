        },
        {
          "name": "Listar TODOS os menus",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/menus?registration=1",
              "host": ["{{base_url}}"],
              "path": ["epp", "menus"],
              "query": [{ "key": "registration", "value": "1" }]
            },
            "description": "Retorna todos os menus (ativos e inativos)."
          }
        },
        {
          "name": "Buscar menu por filtro",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/menus?status=1&description=natal",
              "host": ["{{base_url}}"],
              "path": ["epp", "menus"],
              "query": [
                { "key": "id_menu",     "value": "",      "disabled": true,  "description": "ID do menu" },
                { "key": "status",      "value": "1",     "disabled": false, "description": "1=ativo, 0=inativo" },
                { "key": "description", "value": "natal", "disabled": false, "description": "Texto parcial da descrição" }
              ]
            },
            "description": "Busca menus com filtros: id_menu, status, description."
          }
        },
        {
          "name": "Criar menu",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/menus", "host": ["{{base_url}}"], "path": ["epp", "menus"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Cardápio de Natal 2026\",\n  \"status\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Cria um novo menu.\n\nCampos obrigatórios: description\nOpcionais: status (padrão 1)\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        },
        {
          "name": "Atualizar menu",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/menus/1", "host": ["{{base_url}}"], "path": ["epp", "menus", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Cardápio de Natal 2026 — Atualizado\",\n  \"status\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Atualiza um menu.\n\nCampos obrigatórios: description, status\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        },
        {
          "name": "Excluir menu",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/epp/menus/1", "host": ["{{base_url}}"], "path": ["epp", "menus", "1"] },
            "description": "Remove um menu. Bloqueado se houver itens de cardápio (log_menus) vinculados.\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        }
      ]
    },

    {
      "name": "🗂️ Log Menus (Cardápio × Produto)",
      "item": [
        {
          "name": "Listar todos os itens de cardápio",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/epp/log-menus", "host": ["{{base_url}}"], "path": ["epp", "log-menus"] },
            "description": "Retorna todos os vínculos produto × menu (log_menus), com JOIN de produto e menu."
          }
        },
        {
          "name": "Buscar itens por PLU",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/log-menus?plu_menu=001",
              "host": ["{{base_url}}"],
              "path": ["epp", "log-menus"],
              "query": [{ "key": "plu_menu", "value": "001", "description": "Código PLU do produto no cardápio" }]
            },
            "description": "Filtra itens de cardápio pelo código PLU."
          }
        },
        {
          "name": "Criar item de cardápio",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/log-menus", "host": ["{{base_url}}"], "path": ["epp", "log-menus"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"epp_id_menu\": 1,\n  \"epp_id_product\": 10,\n  \"plu_menu\": \"001\",\n  \"type_base\": 1,\n  \"status_log_menu\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Vincula um produto a um menu.\n\nCampos obrigatórios: epp_id_menu, epp_id_product, plu_menu\nOpcionais: type_base, status_log_menu\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        },
        {
          "name": "Atualizar item de cardápio",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/log-menus/1", "host": ["{{base_url}}"], "path": ["epp", "log-menus", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"epp_id_menu\": 1,\n  \"epp_id_product\": 10,\n  \"plu_menu\": \"001\",\n  \"type_base\": 2,\n  \"status_log_menu\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Atualiza um item de cardápio pelo ID.\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        },
        {
          "name": "Excluir item de cardápio por ID",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/epp/log-menus/1", "host": ["{{base_url}}"], "path": ["epp", "log-menus", "1"] },
            "description": "Remove um item de cardápio pelo ID.\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        },
        {
          "name": "Excluir itens por PLU + Menu",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/log-menus/menu", "host": ["{{base_url}}"], "path": ["epp", "log-menus", "menu"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plu_menu\": \"001\",\n  \"epp_id_menu\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Remove todos os itens com o PLU informado dentro de um menu.\n\nCampos obrigatórios: plu_menu, epp_id_menu\n\nPermissão: EPP_PRODUCTS | MANAGE_EPP"
          }
        }
      ]
    },

    {
      "name": "🛒 Pedidos",
      "item": [
        {
          "name": "Listar pedidos pendentes",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/epp/orders", "host": ["{{base_url}}"], "path": ["epp", "orders"] },
            "description": "Retorna todos os pedidos com status pendente."
          }
        },
        {
          "name": "Listar pedidos por loja de entrega",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/orders?delivery_store=1",
              "host": ["{{base_url}}"],
              "path": ["epp", "orders"],
              "query": [{ "key": "delivery_store", "value": "1", "description": "Código da loja de entrega" }]
            },
            "description": "Filtra pedidos pendentes de uma loja de entrega específica."
          }
        },
        {
          "name": "Buscar pedido por ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/epp/orders/1", "host": ["{{base_url}}"], "path": ["epp", "orders", "1"] },
            "description": "Retorna um pedido específico com todos os seus dados."
          }
        },
        {
          "name": "Criar pedido",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/orders", "host": ["{{base_url}}"], "path": ["epp", "orders"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 42,\n  \"store\": 1,\n  \"name_client\": \"João Silva\",\n  \"date_order\": \"2026-06-08\",\n  \"delivery_date\": \"2026-06-10\",\n  \"delivery_hour\": \"14:00\",\n  \"delivery_store\": 2,\n  \"total\": 150.00,\n  \"fone\": \"11999990000\",\n  \"email\": \"joao@exemplo.com\",\n  \"signal_value\": 50.00,\n  \"menu\": 1,\n  \"id_menu\": 1,\n  \"plu_menu\": \"001\",\n  \"type_rice\": \"branco\",\n  \"description\": \"Festa de aniversário\",\n  \"dessert\": \"Brigadeiro\",\n  \"observation\": \"Sem glúten\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Cria um novo pedido com validação de data de entrega.\n\nCampos OBRIGATÓRIOS: user_id, store, name_client, date_order, delivery_date, delivery_hour, delivery_store, total\n\nCampos opcionais: fone, email, signal_value, menu, id_menu, plu_menu, type_rice, description, dessert, observation\n\nPermissão: EPP_ORDERS | MANAGE_EPP"
          }
        },
        {
          "name": "Atualizar pedido",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/orders/1", "host": ["{{base_url}}"], "path": ["epp", "orders", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": 42,\n  \"store\": 1,\n  \"name_client\": \"João Silva (atualizado)\",\n  \"date_order\": \"2026-06-08\",\n  \"delivery_date\": \"2026-06-11\",\n  \"delivery_hour\": \"16:00\",\n  \"delivery_store\": 2,\n  \"total\": 180.00,\n  \"fone\": \"11999990000\",\n  \"email\": \"joao@exemplo.com\",\n  \"signal_value\": 60.00,\n  \"observation\": \"Sem glúten — confirmado\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Atualiza todos os dados de um pedido.\n\nPermissão: EPP_ORDERS | MANAGE_EPP"
          }
        },
        {
          "name": "Alterar status do pedido",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{base_url}}/epp/orders/1/status", "host": ["{{base_url}}"], "path": ["epp", "orders", "1", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"delivered\": 1\n}",
              "options": { "raw": { "language": "json" } }
            },
            "description": "Marca o pedido como entregue ou cancelado.\n\nValores de delivered:\n  1 = Entregue\n  2 = Cancelado\n\nPermissão: EPP_ORDERS | MANAGE_EPP"
          }
        },
        {
          "name": "Excluir pedido",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{base_url}}/epp/orders/1", "host": ["{{base_url}}"], "path": ["epp", "orders", "1"] },
            "description": "Remove um pedido. Bloqueado se houver itens de venda (log_sales) vinculados.\n\nPermissão: MANAGE_EPP (exclusivo)"
          }
        }
      ]
    },

    {
      "name": "💰 Log de Vendas (Itens do Pedido)",
      "item": [
        {
          "name": "Listar todos os itens",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{base_url}}/epp/log-sales", "host": ["{{base_url}}"], "path": ["epp", "log-sales"] },
            "description": "Retorna todos os itens de venda."
          }
        },
        {
          "name": "Itens de um pedido específico",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/log-sales?epp_id_order=1",
              "host": ["{{base_url}}"],
              "path": ["epp", "log-sales"],
              "query": [{ "key": "epp_id_order", "value": "1", "description": "ID do pedido" }]
            },
            "description": "Retorna todos os itens de um pedido específico."
          }
        },
        {
          "name": "Visão controller (painel de controle)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/log-sales?controller=1",
              "host": ["{{base_url}}"],
              "path": ["epp", "log-sales"],
              "query": [
                { "key": "controller",    "value": "1",          "description": "Habilita visão com JOINs" },
                { "key": "delivery_date", "value": "2026-06-10", "disabled": true, "description": "Filtro opcional por data de entrega" },
                { "key": "delivery_store","value": "1",          "disabled": true, "description": "Filtro opcional por loja de entrega" },
                { "key": "store",         "value": "1",          "disabled": true, "description": "Filtro opcional por loja de origem" }
              ]
            },
            "description": "Retorna itens com JOINs completos (produto, pedido, cliente). Aceita filtros opcionais por delivery_date, delivery_store, store."
          }
        },
        {
          "name": "Visão mobile (produção agregada)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/log-sales?mobile=1",
              "host": ["{{base_url}}"],
              "path": ["epp", "log-sales"],
              "query": [{ "key": "mobile", "value": "1" }]
            },
            "description": "Retorna dados agregados para a visão de produção (uso em dispositivos mobile).\n\nPermissão: EPP_ORDERS | EPP_RECEIPE | MANAGE_EPP"
          }
        },
        {
          "name": "Receita Oracle de um produto",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/epp/log-sales?oracle_receipe=1&seq_produto=12345",
              "host": ["{{base_url}}"],
              "path": ["epp", "log-sales"],
              "query": [
                { "key": "oracle_receipe", "value": "1",     "description": "Habilita consulta de receita no Oracle" },
                { "key": "seq_produto",    "value": "12345", "description": "seq_produto do produto no Consinco — OBRIGATÓRIO" }
              ]
            },
            "description": "Consulta a ficha técnica (receita) de um produto diretamente no Oracle Consinco.\n\nO seq_produto é o campo retornado na rota /epp/products/consinco.\n\nPermissão: EPP_RECEIPE | MANAGE_EPP"
